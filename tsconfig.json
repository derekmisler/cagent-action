{
  "compilerOptions": {
    "declaration": false,
    "esModuleInterop": true,
    "lib": ["ES2024"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", "src/**/__tests__/**", "vite.config.ts", "scripts"],
  "include": ["src/**/*"]
}
